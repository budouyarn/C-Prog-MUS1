/******************************************************************************
Design an algorithm that will prompt for and receive the purchase price of a property and
property type (residential or non-residential) and calculate the buyer’s stamp duty and print
the value.


//prompt the user for input for price of property and property type
//Include a function to compute BSD
//main function for user interaction



*******************************************************************************/
#include <stdio.h>
#include <stdlib.h>
// function to compute BSD
float countProp(int type,float cost){
    float duty = 0;
    // counting BSD for Residential
    if (type == 1) { //type 1 indicating choice 1 back from main
        if (cost < 180000.00) {    //defining boundary for first type of cost type
            duty = cost * 0.01;
        } 
        else if (cost >= 180000.00 && cost <= 600000.00) { //defining cost boundary for second cost type
            duty = cost * 0.02;
        }
        else{
            duty = cost * 0.03; 
        }
    } 
    // counting BSD for Non-Residential
    else if (type == 2) {  //type 2 indicating for choice 2 back from main
        if (cost < 180000.00) {  //defining boundary for first type of cost type
            duty = cost * 0.015;
        } 
        else if (cost >= 180000.00 && cost <= 600000.00) { //defining cost boundary for second cost type
            duty = cost * 0.025;
        } 
        else {
            duty = cost * 0.035;
        }
    }
    return duty; // Send the result back to main function
}

//main function for user interaction
int main()
{
   
//declare and initialise variables
float propCost=0;
int propType=0;
float stampDuty=0;


//Menu for user selection 
printf("\n\t Welcome to Property Buyer Stamp Duty Calculator");
printf("\n\t To continue please enter an option");
printf("\n\t Option 1: Enter 1 for Residential Properties");
printf("\n\t Option 2: Enter 2 for Non Residential Properties");
printf("\n\t Option 3: Enter 3 to Exit");
printf("\n\t Please enter your option[1/2/3]:");  //prompt user to input property type
scanf("%d",&propType);   //save user input
 //Selection of user's option to continue with programming/ exit programm

    
 while(1){ 
      
 switch (propType) {
    case 1: case 2:
    {
    printf("\n\n\tPlease enter your property cost:"); //prompt user to input price of property
    scanf("%f",&propCost);
    // Calling the function to calculate the appropriate BSD after passing the value through function.
        stampDuty = countProp(propType,propCost);
        
if (stampDuty >= 0) { //assuming all calculated charges are >=0
            printf("\n\tThe total Stamp Duty is: $%.2f", stampDuty); // print total property charge
        }
     else { 
        printf("\n\tInvalid Stamp Duty!"); //giving a error message in event where negative cost ranges are entered and passed to functions
     }
     printf("\n\tTo continue with the programme, please enter 1 or 2, or simply enter 3 to exit this programme\n");
     printf("\n\t Option 1: Enter 1 for Residential Properties");
     printf("\n\t Option 2: Enter 2 for Non Residential Properties");
     printf("\n\t Option 3: Enter 3 to Exit");
     printf("\n\t Please enter your option[1/2/3]:");  //prompt user to input property type
     scanf("%d",&propType);
     break;

    case 3: {
      printf("\n\n\tGoodbye!");
    exit(0); //stdlib.h syntax to force quit when option 3 is chosen
    break; }
    } 
 }
   for (propType<0;propType>3;propType++){ //Error handling if option outside 1-3 is entered
       printf("\n\tInvalid option selected! Please re-enter a valid option!\n");
       printf("\n\t Option 1: Enter 1 for Residential Properties");
       printf("\n\t Option 2: Enter 2 for Non Residential Properties");
       printf("\n\t Option 3: Enter 3 to Exit");
       printf("\n\t Please enter your option[1/2/3]:");  //prompt user to input the correct option again
       scanf("%d",&propType); //allow input to be saved
       }
       

   
 }
return 0;
}
