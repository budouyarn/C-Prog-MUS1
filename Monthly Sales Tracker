// Function to perform Selection Sort on a 2D array based on the Sales column
void selectionSort(float data[][2], int length) {
    int counter=0; //initialise counter 
    int innerloop=0; //initialise the innter loop
    int outerloop=0; //initialise outerloop
    
    //define the current work space of month and sales before swapping
    for (counter = 0; counter < length - 1; counter++) { 
        int lowest = counter; // define the counter variable 
        for ( outerloop = counter + 1; outerloop < length; outerloop++) { 
            if (data[outerloop][1] < data[lowest][1]) { //assumming where counter starts as the lowest
                lowest = outerloop;
            }
        }
        // Swapping of month and sales 
        for (innerloop= 0; innerloop < 2; innerloop++) { //innerloop will swap the values according to their month
            float temp = data[lowest][innerloop]; //placing the lowest value into temp placements
            data[lowest][innerloop] = data[counter][innerloop]; // using the empty variable to hold month value
            data[counter][innerloop] = temp; // matching the month to the lowest value.
        }
    }
}

// Function to calculate sum from the 2D array
float findSum(float data[][2], int length) {
    float sum = 0;//initialise variable as 0
    int counter=0;//initialising counter as 0
    for (counter = 0; counter < length; counter++) {
        sum += data[counter][1]; 
    }
    return sum;
}

// Function to search for a specific month/sales pair
int findSales(float data[][2], int length, float targetSales, int targetMonth) {
    int counter=0; //initialise counter to 0

    for (counter = 0; counter < length; counter++) {
        // matching the sales data and month data to appropriate variable holder
        if ((int)data[counter][0] == targetMonth && data[counter][1] == targetSales) {
            return 1; // return values back as a match
        }
    }
    return 0; // return values back as non match
}
